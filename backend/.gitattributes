# Normalizar quebras de linha
* text=auto

# Forçar LF para arquivos de código
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.sql text eol=lf

# Arquivos binários
*.jpg binary
*.png binary
*.gif binary
*.jar binary
*.class binary